# Neon PostgreSQL - opret gratis på neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/linkedin_automation?sslmode=require

# Anthropic / Claude API - din API nøgle fra console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# Cron Secret - generer en tilfældig streng (bruges til at beskytte cron endpoints)
# Eksempel: openssl rand -hex 32
CRON_SECRET=your_random_secret_string_here

# ── Phantombuster ─────────────────────────────────────────────────────────────
# Find din API nøgle: app.phantombuster.com → Settings → API
PHANTOMBUSTER_API_KEY=your_phantombuster_api_key

# Phantom IDs - find dem i URL'en når du åbner et Phantom i dashboardet
# Eks: app.phantombuster.com/phantom/123456 → ID er 123456
PHANTOM_SEARCH_EXPORT_ID=123456
PHANTOM_NETWORK_BOOSTER_ID=123457
PHANTOM_MESSAGE_SENDER_ID=123458

# LinkedIn session cookie
# Hent den fra Chrome: F12 → Application → Cookies → linkedin.com → li_at
LINKEDIN_LI_AT=AQE...

# ── Lead-søgning kriterier ────────────────────────────────────────────────────
# Keywords roteres dagligt (ét per dag)
LEAD_SEARCH_KEYWORDS=CEO,founder,ejer,direktør
LEAD_SEARCH_LOCATION=Denmark
